{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Grapic",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-Wno-sign-compare",
                "-Wno-unused-variable",
                "-g",
                "-I${workspaceFolder}/src",
                "-I/usr/include/SDL2",
                "-o",
                "${workspaceFolder}/bin/${fileBasenameNoExtension}",
                "${file}",
                "${workspaceFolder}/src/Grapic.cpp",
                "-lSDL2",
                "-lSDL2_image",
                "-lSDL2_ttf",
                "-lSDL2_mixer"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compile any Grapic C++ file in the workspace"
        },
        {
            "label": "Run Grapic",
            "type": "shell",
            "command": "${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Compile Grapic",
            "problemMatcher": [],
            "detail": "Run the compiled Grapic program"
        },
        {
            "label": "Clean build",
            "type": "shell",
            "command": "rm -f ${workspaceFolder}/bin/${fileBasenameNoExtension}",
            "group": "build",
            "problemMatcher": [],
            "detail": "Delete the executable to rebuild cleanly"
        }
    ]
}